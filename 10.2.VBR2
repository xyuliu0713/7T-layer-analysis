#!/bin/bash

export SUBJECTS_DIR=/Users/molin/Downloads/tangdu_hosp/finished/data
cd /Users/molin/Downloads/tangdu_hosp/finished/data/Coregistrations
bbregister \
  --s Freesurfer \
  --mov /Users/molin/Downloads/tangdu_hosp/finished/data/Realigned/meanFunctional.nii \
  --reg /Users/molin/Downloads/tangdu_hosp/finished/data/Coregistrations/register_VolumeCoregister.dat \
  --bold \
  --init-fsl

% check results
tkregisterfv \
--mov /Users/molin/Downloads/tangdu_hosp/finished/data/Realigned/meanFunctional.nii \
--reg /Users/molin/Downloads/tangdu_hosp/finished/data/Coregistrations/register_VolumeCoregister.dat \
--surfs \
--sd /Users/molin/Downloads/tangdu_hosp/finished/data


