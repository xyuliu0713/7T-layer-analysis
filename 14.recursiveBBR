% Realignment configuration - using settings from petkok's code, assuming they are fine...

rootDir = '/Users/molin/Downloads/tangdu_hosp/finished/data';
subjectDir = '/Users/molin/Downloads/tangdu_hosp/finished/data';

addpath('/Volumes/xyu/MSc neuroimaging/project/AnalysesCode/OpenFmriAnalysis-master/Interface/Registration')
addpath('/Volumes/xyu/MSc neuroimaging/project/AnalysesCode/OpenFmriAnalysis-master/Core')

configuration = [];
configuration.i_SubjectDirectory = rootDir;
configuration.i_ReferenceVolume = 'Realigned/meanFunctional.nii';
configuration.i_Boundaries = 'Coregistrations/Anat2FuncBoundaries_BBR.mat';
configuration.o_Boundaries = 'Coregistrations/Anat2FuncBoundaries_recurs.mat';

registrationConfiguration = [];
