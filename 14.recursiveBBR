registrationConfiguration.ContrastMethod        = 'gradient';
registrationConfiguration.OptimisationMethod    = 'GreveFischl';
registrationConfiguration.Mode                  = 'rsyt'; %'rsxt'
registrationConfiguration.NumberOfIterations    = 6; % 6 = default, 8 = recommended for whole brain.
registrationConfiguration.Accuracy              = 30;
registrationConfiguration.DynamicAccuracy       = true;
registrationConfiguration.MultipleLoops         = true;
registrationConfiguration.qsub                  = false;
registrationConfiguration.Display              	= 'on';

tvm_recursiveBoundaryRegistration(configuration,registrationConfiguration);
      
clear configuration registrationConfiguration; 
